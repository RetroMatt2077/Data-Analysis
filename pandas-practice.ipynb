# ==========================================
# Pandas Practice
# Learn the basics of data analysis with Pandas
# ==========================================

import pandas as pd
import numpy as np

print("=" * 50)
print("PANDAS PRACTICE")
print("=" * 50)

# -----------------------------
# Create Sample Data
# -----------------------------

data = {
    "Name": ["Alice", "Bob", "Charlie", "Diana", "Ethan", "Fiona"],
    "Age": [24, 30, 22, 27, 35, 29],
    "Score": [88, 92, 79, 95, 84, 91]
}

df = pd.DataFrame(data)

print("\nOriginal DataFrame:")
print(df)

# -----------------------------
# View Data
# -----------------------------

print("\nFirst Five Rows:")
print(df.head())

print("\nLast Five Rows:")
print(df.tail())

print("\nData Types:")
print(df.dtypes)

print("\nGeneral Information:")
df.info()

print("\nSummary Statistics:")
print(df.describe())

# -----------------------------
# Select Columns
# -----------------------------

print("\nNames:")
print(df["Name"])

print("\nNames and Scores:")
print(df[["Name", "Score"]])

# -----------------------------
# Select Rows
# -----------------------------

print("\nFirst Row:")
print(df.loc[0])

print("\nRows 2-4:")
print(df.loc[1:3])

# -----------------------------
# Filter Data
# -----------------------------

high_scores = df[df["Score"] >= 90]

print("\nStudents Scoring 90 or Higher:")
print(high_scores)

# -----------------------------
# Add New Column
# -----------------------------

df["Passed"] = df["Score"] >= 80

print("\nAdded 'Passed' Column:")
print(df)

# -----------------------------
# Add Grade Column
# -----------------------------

def grade(score):
    if score >= 90:
        return "A"
    elif score >= 80:
        return "B"
    elif score >= 70:
        return "C"
    else:
        return "D"

df["Grade"] = df["Score"].apply(grade)

print("\nAdded Grades:")
print(df)

# -----------------------------
# Sort Data
# -----------------------------

sorted_df = df.sort_values(by="Score", ascending=False)

print("\nSorted by Score:")
print(sorted_df)

# -----------------------------
# Statistics
# -----------------------------

print("\nAverage Score:", df["Score"].mean())
print("Highest Score:", df["Score"].max())
print("Lowest Score:", df["Score"].min())
print("Median Score:", df["Score"].median())

# -----------------------------
# Value Counts
# -----------------------------

print("\nGrade Distribution:")
print(df["Grade"].value_counts())

# -----------------------------
# Save CSV
# -----------------------------

df.to_csv("students.csv", index=False)

print("\nSaved DataFrame to students.csv")

# -----------------------------
# Read CSV
# -----------------------------

loaded = pd.read_csv("students.csv")

print("\nLoaded CSV:")
print(loaded)

# -----------------------------
# Grouping Example
# -----------------------------

grouped = loaded.groupby("Grade")["Score"].mean()

print("\nAverage Score by Grade:")
print(grouped)

print("\nPractice Complete!")
print("=" * 50)
